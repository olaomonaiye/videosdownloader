# ============================================================
# VIDEO DOWNLOADER PLATFORM - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Backend reads from .env, Frontend reads from .env.local
# ============================================================

# ── Branding (Backend) ──
SITE_NAME="VideoDownloader"
SITE_URL="http://localhost:7600"
SITE_ADMIN_EMAIL="admin@example.com"

# ── Server Ports ──
API_PORT=7500
FRONTEND_PORT=7600
NODE_ENV=development

# ── Database ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/videodownloader?schema=public"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── JWT Authentication ──
JWT_SECRET="change-this-to-a-random-256-bit-secret-key-in-production"
JWT_REFRESH_SECRET="change-this-to-another-random-256-bit-secret-key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── S3-Compatible Object Storage ──
S3_BUCKET="platform-assets"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ── yt-dlp ──
YTDLP_PATH="yt-dlp"
YTDLP_AUTO_UPDATE=true
YTDLP_UPDATE_CRON="0 3 * * *"
YTDLP_TIMEOUT=120000
YTDLP_MAX_FILESIZE="500M"

# ── BullMQ Worker ──
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3

# ── Rate Limiting ──
RATE_LIMIT_DOWNLOAD=30
RATE_LIMIT_GENERAL=100
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW_MS=60000

# ── Logging ──
LOG_LEVEL="debug"

# ── Admin Seed (first run only) ──
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeThisPassword123!"
ADMIN_NAME="Super Admin"

# ── Analytics (Optional) ──
GOOGLE_ANALYTICS_ID=""
CLARITY_PROJECT_ID=""

# ── CORS ──
CORS_ORIGIN="http://localhost:7600"
