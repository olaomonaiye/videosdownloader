# ============================================================
# FRONTEND - Environment Configuration (Next.js)
# ============================================================
# Copy this file to frontend/.env.local
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ============================================================

# ── Branding (Public) ──
NEXT_PUBLIC_SITE_NAME="VideoDownloader"
NEXT_PUBLIC_SITE_URL="http://localhost:7600"
NEXT_PUBLIC_SITE_TAGLINE="Download Any Video, Anywhere"
NEXT_PUBLIC_SITE_LOGO_URL="/images/logo.svg"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# ── API Connection ──
NEXT_PUBLIC_API_URL="http://localhost:7500"
API_URL_INTERNAL="http://localhost:7500"

# ── Analytics (Optional) ──
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
